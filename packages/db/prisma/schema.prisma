// ────────────────────────────────────────────────────────
// Prisma Schema – AI Marketplace
// ────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant ──────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users    User[]
  products Product[]

  @@map("tenants")
}

// ── User ────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CREATOR
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String   // hashed; placeholder for auth
  role      UserRole @default(VIEWER)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

// ── Product (Bot / Automation listing) ──────────────────

enum PricingModel {
  FREE
  ONE_TIME
  SUBSCRIPTION
  USAGE_BASED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Product {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  name         String
  slug         String
  description  String
  price        Float         @default(0)
  pricingModel PricingModel  @default(FREE) @map("pricing_model")
  status       ProductStatus @default(DRAFT)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("products")
}
