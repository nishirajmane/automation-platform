# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketplace?schema=public

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Auth / JWT
# ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
