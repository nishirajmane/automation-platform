{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "paths": {
      "@app/db": ["./packages/db/src/index.ts"],
      "@app/shared-types": ["./packages/shared-types/src/index.ts"],
      "@app/shared-utils": ["./packages/shared-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
